 -- Auto pick up
local autoPickUpActive = false
local autoPickUpThread = nil

autoPickUpBtn.MouseButton1Click:Connect(function()
	autoPickUpActive = not autoPickUpActive
	autoPickUpBtn.Text = autoPickUpActive and "Auto Pick Up: ON" or "Auto Pick Up"

	if autoPickUpActive then
		autoPickUpThread = task.spawn(function()
			while autoPickUpActive do
				local character = player.Character
				if character then
					local root = character:FindFirstChild("HumanoidRootPart")
					if root then
						for _, prompt in pairs(workspace:GetDescendants()) do
							if prompt:IsA("ProximityPrompt") and prompt.Enabled then
								local parentPart = prompt.Parent:IsA("BasePart") and prompt.Parent or nil
								if parentPart then
									local distance = (parentPart.Position - root.Position).Magnitude
									if distance <= prompt.MaxActivationDistance then
										-- Giữ nhặt cho đến khi prompt biến mất hoặc tắt
										while autoPickUpActive and prompt.Enabled and prompt.Parent do
											fireproximityprompt(prompt)
											task.wait(0.1)
										end
									end
								end
							end
						end
					end
				end
				task.wait(0.1)
			end
		end)
	else
		if autoPickUpThread then
			task.cancel(autoPickUpThread)
			autoPickUpThread = nil
		end
	end
end)
 -- Auto E
